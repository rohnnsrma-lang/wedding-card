
<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>दिव्या 💍 विकास — शुभ विवाह निमंत्रण</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Devanagari:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

body{
  background:#0a0a15;
  font-family:"Noto Serif Devanagari",serif;
  min-height:100vh;
  overflow-x:hidden;
}

/* Simple bg - no animations */
.bg-fixed{
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background:linear-gradient(160deg,#0a0a15 0%,#12111f 40%,#0a0a15 100%);
}
.orb{position:fixed;border-radius:50%;filter:blur(60px);pointer-events:none;z-index:0;opacity:.5}
.o1{width:400px;height:400px;background:rgba(80,20,120,.15);top:-80px;left:-80px}
.o2{width:350px;height:350px;background:rgba(150,120,0,.1);top:20%;right:-60px}
.o3{width:300px;height:300px;background:rgba(150,20,80,.12);bottom:-60px;left:10%}
#stars,#petals{position:fixed;inset:0;z-index:0;pointer-events:none}

.lb{position:fixed;left:0;right:0;background:#000;z-index:9000;height:50px;transition:height 1s ease .2s}
.lb.top{top:0}.lb.bot{bottom:0}
body.open .lb{height:0}

.cw{
  position:relative;z-index:10;max-width:860px;margin:20px auto;padding:12px;
  opacity:0;transform:translateY(30px);
  transition:opacity .8s ease 1.4s,transform .8s ease 1.4s;
}
body.open .cw{opacity:1;transform:translateY(0)}

.card{
  position:relative;border-radius:12px;overflow:hidden;
  background:linear-gradient(155deg,#0d0d1a 0%,#10101f 30%,#0a0a15 65%,#080810 100%);
  border:1px solid rgba(180,140,0,.4);
  box-shadow:
    0 0 0 2px rgba(8,8,15,.9),
    0 0 0 3px rgba(180,140,0,.18),
    0 0 50px rgba(180,140,0,.12),
    0 25px 60px rgba(0,0,0,.8);
}

.sbar{position:absolute;left:0;right:0;height:2px;z-index:20;background:linear-gradient(90deg,transparent,#B8A000,#FF6B00,#E91E8C,#00D4FF,#B8A000,transparent)}
.sbar.t{top:0}.sbar.b{bottom:0}

.inner-border{position:absolute;inset:10px;border-radius:10px;pointer-events:none;z-index:1;border:1px solid rgba(180,140,0,.15)}
.vignette{position:absolute;inset:0;pointer-events:none;z-index:2;background:radial-gradient(ellipse at center,transparent 25%,rgba(0,0,8,.5) 100%)}
.grain{position:absolute;inset:0;pointer-events:none;z-index:3;opacity:.015;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E")}

.cn{position:absolute;width:70px;height:70px;z-index:15;pointer-events:none}
.cn.tl{top:0;left:0}.cn.tr{top:0;right:0;transform:scaleX(-1)}
.cn.bl{bottom:0;left:0;transform:scaleY(-1)}.cn.br{bottom:0;right:0;transform:scale(-1)}

.content{position:relative;z-index:10;padding:36px 24px}

.r0,.rl,.rr{transition:opacity .7s ease,transform .7s ease}
.r0{opacity:0;transform:translateY(20px)}
.rl{opacity:0;transform:translateX(-30px)}
.rr{opacity:0;transform:translateX(30px)}
.r0.vis,.rl.vis,.rr.vis{opacity:1;transform:none}

/* GANESHA */
.g-wrap{text-align:center;margin:0 0 18px;position:relative}
.g-shrine{position:relative;display:inline-block;width:min(200px,55%)}

.g-rays{
  position:absolute;inset:-30px;border-radius:50%;pointer-events:none;z-index:1;
  background:conic-gradient(
    from 0deg,transparent 0deg,rgba(180,140,0,.15) 15deg,transparent 30deg,
    transparent 60deg,rgba(200,20,100,.12) 75deg,transparent 90deg,
    transparent 120deg,rgba(180,140,0,.15) 135deg,transparent 150deg,
    transparent 180deg,rgba(200,20,100,.12) 195deg,transparent 210deg,
    transparent 240deg,rgba(180,140,0,.15) 255deg,transparent 270deg,
    transparent 300deg,rgba(200,20,100,.12) 315deg,transparent 330deg,
    transparent 360deg
  );
}

.g-glow{
  position:absolute;inset:-10px;border-radius:50%;pointer-events:none;z-index:1;
  background:radial-gradient(circle,rgba(180,140,0,.4) 0%,rgba(200,20,100,.15) 40%,transparent 65%);
}

.g-ring1{
  position:absolute;inset:-22px;border-radius:50%;pointer-events:none;z-index:2;
  border:2px solid;border-top-color:#B8A000;border-right-color:#FF6B00;
  border-bottom-color:#E91E8C;border-left-color:#00D4FF;
  box-shadow:0 0 10px rgba(180,140,0,.25);
}

.g-ring2{
  position:absolute;inset:-12px;border-radius:50%;pointer-events:none;z-index:2;
  border:1.5px solid;border-top-color:#E91E8C;border-right-color:#9C27B0;
  border-bottom-color:#B8A000;border-left-color:#FF6B00;
}

.g-img{
  width:100%;border-radius:50%;display:block;position:relative;z-index:3;
  border:3px solid #B8A000;
  outline:1.5px solid #FF6B00;
  box-shadow:0 0 20px rgba(180,140,0,.7),0 0 40px rgba(200,20,100,.3);
}

.g-sp{position:absolute;pointer-events:none;z-index:4;font-size:13px;color:#FFD700;text-shadow:0 0 6px #FFD700}
.s1{top:-12px;left:22%}.s2{top:5%;right:-12px}
.s3{bottom:5%;right:-12px}.s4{bottom:-10px;left:32%}
.s5{bottom:8%;left:-12px}.s6{top:18%;left:-14px}
.s7{top:-5px;right:20%}.s8{bottom:0%;right:10%}

.g-pt{position:absolute;font-size:16px;pointer-events:none;z-index:4}
.p1{top:-6px;left:5%}.p2{top:0%;right:1%}
.p3{bottom:0%;right:4%}.p4{bottom:-6px;left:10%}

.g-name{
  display:inline-block;margin-top:14px;padding:6px 20px;border-radius:25px;
  border:1px solid rgba(180,140,0,.5);background:rgba(180,140,0,.06);
  color:#FFD700;font-size:12px;font-weight:600;letter-spacing:2px;
  text-shadow:0 0 10px rgba(180,140,0,.6);
}

.om-row{text-align:center;margin:6px 0 3px}
.om{
  font-size:48px;display:inline-block;
  background:linear-gradient(135deg,#FFD700,#FF6B00,#FFD700);
  background-size:200% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 10px rgba(180,140,0,.6));
}
.bless{color:#D8C066;font-size:11px;letter-spacing:2px;text-align:center;opacity:.85;margin:2px 0}

.divrow{display:flex;align-items:center;gap:8px;margin:12px 0}
.divline{flex:1;height:0.5px;background:linear-gradient(90deg,transparent,rgba(100,20,140,.4),#B8A000,rgba(150,20,80,.4),transparent)}
.divgem{font-size:12px;flex-shrink:0;color:#B8A000;text-shadow:0 0 8px rgba(180,140,0,.5)}

.title{
  text-align:center;font-size:clamp(24px,5vw,42px);font-weight:900;
  letter-spacing:3px;line-height:1.2;margin:8px 0 3px;
  background:linear-gradient(135deg,#B8A000,#FFD700,#FF6B00,#FFD700,#B8A000);
  background-size:200% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 12px rgba(180,140,0,.45));
}
.subtitle{text-align:center;color:#B8A8D8;font-size:12px;opacity:.85;font-style:italic;margin:3px 0 6px;letter-spacing:1px}

.couple-row{display:flex;align-items:center;justify-content:center;gap:10px;margin:16px 0;flex-wrap:wrap}
.name-box{
  text-align:center;flex:1;min-width:120px;max-width:200px;border-radius:8px;
  padding:14px 10px;background:rgba(10,0,30,.75);border:1px solid rgba(180,140,0,.35);
  box-shadow:0 0 15px rgba(80,20,120,.12);position:relative;overflow:hidden;
}
.nb-sweep{
  position:absolute;top:0;left:-100%;width:50%;height:100%;pointer-events:none;
  background:linear-gradient(90deg,transparent,rgba(180,140,0,.04),transparent);
}
.name-role{font-size:8px;color:rgba(180,140,0,.6);letter-spacing:3px;text-transform:uppercase;margin-bottom:6px}
.name-main{
  font-size:clamp(22px,4.5vw,32px);font-weight:700;
  background:linear-gradient(135deg,#FFD700,#E91E8C,#FFD700);
  background-size:180% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  display:block;
}
.name-eng{color:rgba(190,170,240,.5);font-size:10px;margin-top:2px;letter-spacing:1px}
.heart-mid{font-size:32px;flex-shrink:0;filter:drop-shadow(0 0 8px #E91E8C)}

.baarat-wrap{text-align:center;margin:12px 0}
.blabel{font-size:9px;letter-spacing:3px;color:rgba(180,140,0,.6);margin-bottom:6px;text-transform:uppercase}
.bsvg{width:100%;max-width:680px;filter:drop-shadow(0 0 8px rgba(180,140,0,.2))}

.families{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:14px 0}
@media(max-width:500px){.families{grid-template-columns:1fr}}
.fam-box{
  border-radius:8px;padding:12px 10px;position:relative;overflow:hidden;
  background:rgba(8,0,24,.8);border:1px solid rgba(180,140,0,.28);
  box-shadow:0 0 12px rgba(80,20,120,.1);
}
.fb-sweep{
  position:absolute;top:0;left:-100%;width:50%;height:100%;pointer-events:none;
  background:linear-gradient(90deg,transparent,rgba(180,140,0,.03),transparent);
}
.fam-label{
  font-size:8px;color:#D8C066;letter-spacing:2px;margin-bottom:8px;
  text-align:center;padding-bottom:6px;border-bottom:0.5px solid rgba(180,140,0,.15);
  text-transform:uppercase;
}
.fam-line{color:rgba(245,240,235,.85);font-size:12px;line-height:1.7}
.fam-hi{color:#FFD700;font-weight:600;font-size:13px;text-shadow:0 0 8px rgba(180,140,0,.5)}
.fam-sub{color:rgba(190,170,240,.8)}

.evhead{text-align:center;font-size:10px;letter-spacing:3px;color:rgba(180,140,0,.7);text-transform:uppercase;margin:16px 0 10px}
.ev{
  position:relative;border-radius:6px;padding:12px 14px 12px 16px;margin-bottom:8px;
  background:rgba(8,0,24,.8);border:0.5px solid rgba(180,140,0,.25);
  transition:transform .2s,box-shadow .2s;overflow:hidden;
}
.ev:hover{transform:translateX(2px);box-shadow:0 0 16px rgba(180,140,0,.15)}
.ev-accent{
  position:absolute;left:0;top:0;bottom:0;width:2px;border-radius:6px 0 0 6px;
  background:linear-gradient(to bottom,#B8A000,#FF6B00,#E91E8C,#B8A000);
  background-size:100% 200%;
}
.ev-shine{
  position:absolute;top:0;left:-100%;width:45%;height:100%;pointer-events:none;
  background:linear-gradient(90deg,transparent,rgba(180,140,0,.03),transparent);
}
.ev-name{color:#FFD700;font-size:13px;font-weight:600;margin-bottom:3px;padding-right:75px}
.ev-desc{color:rgba(245,240,235,.8);font-size:11.5px;line-height:1.5}
.ev-time{
  position:absolute;right:10px;top:12px;color:#D8C066;font-size:9.5px;
  background:rgba(180,140,0,.08);border:0.5px solid rgba(180,140,0,.3);
  padding:2px 8px;border-radius:15px;letter-spacing:0.5px;
}
.ev.vidai .ev-accent{background:linear-gradient(to bottom,#E91E8C,#FF80C0,#E91E8C)}
.ev.vidai .ev-name{color:#FF80C0}
.ev.vidai .ev-time{color:#FF80C0;border-color:rgba(233,30,140,.4)}

.vidai-wrap{text-align:center;margin:14px 0 4px}
.vidai-label{color:#E91E8C;font-size:10px;letter-spacing:2px;margin-bottom:6px;text-shadow:0 0 8px rgba(233,30,140,.5)}
.vidai-svg{width:min(480px,95%);filter:drop-shadow(0 0 12px rgba(233,30,140,.4))}

.scratch-sec{margin:20px 0;text-align:center}
.sc-label{
  font-size:12px;letter-spacing:1.5px;margin-bottom:8px;font-weight:600;
  background:linear-gradient(135deg,#B8A000,#E91E8C,#B8A000);
  background-size:180% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  display:block;
}
.sc-hint{color:rgba(245,240,235,.55);font-size:10px;margin-bottom:8px}
.sc-wrap{
  position:relative;display:inline-block;border-radius:10px;overflow:hidden;
  box-shadow:0 0 25px rgba(180,140,0,.25);cursor:crosshair;touch-action:none;
}
.sc-reveal{
  border-radius:10px;padding:20px 24px;min-width:min(340px,84vw);text-align:center;
  background:linear-gradient(145deg,#0a0a15,#08081e,#0a0a15);
  border:1.5px solid rgba(180,140,0,.45);
}
.r-ttl{font-size:9px;color:rgba(180,140,0,.7);letter-spacing:3px;margin-bottom:12px;text-transform:uppercase}
.r-date{
  font-size:clamp(20px,4.5vw,28px);font-weight:700;margin-bottom:3px;
  background:linear-gradient(135deg,#FFD700,#FF6B00,#FFD700);
  background-size:180% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.r-day{color:#FF6B00;font-size:13px;font-weight:600;margin-bottom:10px;text-shadow:0 0 8px rgba(200,20,100,.5)}
.r-line{color:rgba(245,240,235,.88);font-size:12px;margin:4px 0;line-height:1.6}
.r-badge{
  display:inline-block;margin-top:10px;background:rgba(180,140,0,.08);
  border:0.5px solid rgba(180,140,0,.35);border-radius:18px;
  padding:4px 14px;color:#FFD700;font-size:10px;letter-spacing:1px;
}
.fw{font-size:20px;display:block;margin-bottom:6px}
#scratchCanvas{position:absolute;top:0;left:0;border-radius:10px;cursor:crosshair;touch-action:none}
.sc-done{color:#FFD700;font-size:11px;margin-top:8px;opacity:0;transition:opacity .5s;letter-spacing:0.5px}
.sc-done.show{opacity:1}

.venue-box{
  border-radius:8px;padding:18px;text-align:center;margin:14px 0;
  background:rgba(8,0,24,.8);border:1px solid rgba(180,140,0,.3);
  box-shadow:0 0 12px rgba(80,20,120,.1);position:relative;overflow:hidden;
}
.v-sweep{
  position:absolute;top:0;left:-100%;width:45%;height:100%;pointer-events:none;
  background:linear-gradient(90deg,transparent,rgba(180,140,0,.03),transparent);
}
.v-icon{font-size:26px;margin-bottom:6px}
.v-title{color:#FFD700;font-size:12px;font-weight:600;letter-spacing:1.5px;margin-bottom:8px;text-shadow:0 0 8px rgba(180,140,0,.5)}
.v-addr{color:rgba(245,240,235,.88);font-size:12.5px;line-height:1.8}
a[href^="tel"]{color:#FFD700;text-decoration:none;font-weight:600;letter-spacing:1px;text-shadow:0 0 6px rgba(180,140,0,.5)}

.diyas{display:flex;justify-content:center;gap:14px;margin:8px 0}
.diya{font-size:20px}

.footer-msg{text-align:center;font-size:12px;font-style:italic;opacity:.88;margin:10px 0;line-height:1.7;color:#B8A8D8}
.footer-names{
  text-align:center;font-size:13px;font-weight:700;letter-spacing:1.5px;margin-top:8px;
  background:linear-gradient(135deg,#B8A000,#FFD700,#B8A000);background-size:180% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}

@media(max-width:520px){
  .content{padding:24px 14px}
  .couple-row{gap:6px}
  .name-box{padding:10px 8px}
}
</style>
</head>
<body>

<!-- Letterbox cinematic bars -->
<div class="lb top"></div>
<div class="lb bot"></div>

<!-- Background layers -->
<div class="bg-fixed"></div>
<div class="orb o1"></div>
<div class="orb o2"></div>
<div class="orb o3"></div>
<canvas id="stars"></canvas>
<canvas id="petals"></canvas>

<div class="cw" id="cw">
 <div class="card">
  <div class="sbar t"></div>
  <div class="sbar b"></div>
  <div class="inner-border"></div>
  <div class="vignette"></div>
  <div class="grain"></div>

  <!-- Corner SVGs -->
  <div class="cn tl"><svg viewBox="0 0 85 85" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 3L38 3M3 3L3 38" stroke="#C8A000" stroke-width="2.2"/><circle cx="3" cy="3" r="3.5" fill="#C8A000"/><circle cx="38" cy="3" r="2" fill="#C8A000" opacity=".6"/><circle cx="3" cy="38" r="2" fill="#C8A000" opacity=".6"/><path d="M13 3 C13 13 3 13 3 13" stroke="#C8A000" stroke-width="1.3" fill="none" opacity=".85"/><path d="M24 3 C24 24 3 24 3 24" stroke="#C8A000" stroke-width=".8" fill="none" opacity=".5"/><path d="M34 3 C34 34 3 34 3 34" stroke="#C8A000" stroke-width=".5" fill="none" opacity=".3"/><circle cx="20" cy="8" r="1.8" fill="#FF6B00" opacity=".65"/><circle cx="8" cy="20" r="1.8" fill="#FF6B00" opacity=".65"/><circle cx="28" cy="4" r="1.2" fill="#C8A000" opacity=".5"/><circle cx="4" cy="28" r="1.2" fill="#C8A000" opacity=".5"/></svg></div>
  <div class="cn tr"><svg viewBox="0 0 85 85" fill="none"><path d="M3 3L38 3M3 3L3 38" stroke="#C8A000" stroke-width="2.2"/><circle cx="3" cy="3" r="3.5" fill="#C8A000"/><path d="M13 3 C13 13 3 13 3 13" stroke="#C8A000" stroke-width="1.3" fill="none" opacity=".85"/><path d="M24 3 C24 24 3 24 3 24" stroke="#C8A000" stroke-width=".8" fill="none" opacity=".5"/><path d="M34 3 C34 34 3 34 3 34" stroke="#C8A000" stroke-width=".5" fill="none" opacity=".3"/><circle cx="20" cy="8" r="1.8" fill="#FF6B00" opacity=".65"/><circle cx="8" cy="20" r="1.8" fill="#FF6B00" opacity=".65"/></svg></div>
  <div class="cn bl"><svg viewBox="0 0 85 85" fill="none"><path d="M3 3L38 3M3 3L3 38" stroke="#C8A000" stroke-width="2.2"/><circle cx="3" cy="3" r="3.5" fill="#C8A000"/><path d="M13 3 C13 13 3 13 3 13" stroke="#C8A000" stroke-width="1.3" fill="none" opacity=".85"/><path d="M24 3 C24 24 3 24 3 24" stroke="#C8A000" stroke-width=".8" fill="none" opacity=".5"/><path d="M34 3 C34 34 3 34 3 34" stroke="#C8A000" stroke-width=".5" fill="none" opacity=".3"/><circle cx="20" cy="8" r="1.8" fill="#FF6B00" opacity=".65"/><circle cx="8" cy="20" r="1.8" fill="#FF6B00" opacity=".65"/></svg></div>
  <div class="cn br"><svg viewBox="0 0 85 85" fill="none"><path d="M3 3L38 3M3 3L3 38" stroke="#C8A000" stroke-width="2.2"/><circle cx="3" cy="3" r="3.5" fill="#C8A000"/><path d="M13 3 C13 13 3 13 3 13" stroke="#C8A000" stroke-width="1.3" fill="none" opacity=".85"/><path d="M24 3 C24 24 3 24 3 24" stroke="#C8A000" stroke-width=".8" fill="none" opacity=".5"/><path d="M34 3 C34 34 3 34 3 34" stroke="#C8A000" stroke-width=".5" fill="none" opacity=".3"/><circle cx="20" cy="8" r="1.8" fill="#FF6B00" opacity=".65"/><circle cx="8" cy="20" r="1.8" fill="#FF6B00" opacity=".65"/></svg></div>

  <div class="content">

   <!-- GANESHA -->
   <div class="g-wrap r0">
    <div class="g-shrine">
      <div class="g-rays"></div>
      <div class="g-glow"></div>
      <div class="g-ring1"></div>
      <div class="g-ring2"></div>
      <span class="g-sp s1">✦</span><span class="g-sp s2">✦</span>
      <span class="g-sp s3">✦</span><span class="g-sp s4">✦</span>
      <span class="g-sp s5">✦</span><span class="g-sp s6">✦</span>
      <span class="g-sp s7">✦</span><span class="g-sp s8">✦</span>
      <span class="g-pt p1">🌸</span><span class="g-pt p2">🌺</span>
      <span class="g-pt p3">🌸</span><span class="g-pt p4">🌺</span>
      <img class="g-img" src="data:image/webp;base64," alt="श्री गणेश जी"/>
    </div>
    <div><span class="g-name">🌸 श्री गणेशाय नमः 🌸</span></div>
   </div>

   <!-- OM -->
   <div class="om-row r0"><span class="om">ॐ</span></div>
   <p class="bless r0">॥ शुभम् भवतु — मंगलम् भवतु ॥</p>
   <p class="bless r0" style="font-size:11px;margin-top:2px">ईश्वर परमात्मा की कृपा से</p>

   <div class="divrow r0"><div class="divline"></div><span class="divgem">✦ ❋ ✦</span><div class="divline"></div></div>

   <div class="diyas r0">
     <span class="diya">🪔</span><span class="diya">🌺</span><span class="diya">🪔</span><span class="diya">🌺</span><span class="diya">🪔</span>
   </div>

   <h1 class="title r0">शुभ विवाह निमंत्रण</h1>
   <p class="subtitle r0">— एक पवित्र बंधन, दो परिवारों का मिलन —</p>

