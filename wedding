   </div>

  </div>
 </div>
</div>

<script>
// ── LETTERBOX OPEN ──
window.addEventListener("load", () => {
  setTimeout(() => {
    document.body.classList.add("open");
  }, 100);
});

// ── STARFIELD ──
(function(){
  const c = document.getElementById("stars");
  const ctx = c.getContext("2d");
  let W, H;
  const stars = [];
  function resize(){ W = c.width = innerWidth; H = c.height = innerHeight; }
  resize(); window.addEventListener("resize", resize);
  for(let i = 0; i < 180; i++){
    stars.push({
      x: Math.random() * 2000, y: Math.random() * 2000,
      r: Math.random() * 1.4 + 0.3,
      a: Math.random() * 0.7 + 0.2,
      t: Math.random() * Math.PI * 2,
      sp: Math.random() * 0.025 + 0.005,
      col: Math.random() > 0.7 ? "#FF80C0" : "#FFE566"
    });
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    stars.forEach(s => {
      s.t += s.sp;
      ctx.save();
      ctx.globalAlpha = s.a * (0.5 + 0.5 * Math.sin(s.t));
      ctx.fillStyle = s.col;
      ctx.shadowColor = s.col;
      ctx.shadowBlur = 5;
      ctx.beginPath();
      ctx.arc(s.x % W, s.y % H, s.r, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

// ── FLOATING PETALS ──
(function(){
  const c = document.getElementById("petals");
  const ctx = c.getContext("2d");
  let W, H;
  function resize(){ W = c.width = innerWidth; H = c.height = innerHeight; }
  resize(); window.addEventListener("resize", resize);
  const EMOJIS = ["🌸","🌺","🌹","💮","🌼"];
  const petals = [];
  for(let i = 0; i < 20; i++){
    petals.push({
      x: Math.random() * 1600,
      y: Math.random() * -1000 - 100,
      vx: (Math.random() - 0.5) * 0.7,
      vy: Math.random() * 0.6 + 0.3,
      rot: Math.random() * 360,
      vr: (Math.random() - 0.5) * 1.5,
      sz: 16 + Math.random() * 14,
      em: EMOJIS[Math.floor(Math.random() * EMOJIS.length)],
      a: Math.random() * 0.5 + 0.3
    });
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    petals.forEach(p => {
      p.x += p.vx; p.y += p.vy; p.rot += p.vr;
      if(p.y > H + 60){ p.y = -60; p.x = Math.random() * W; }
      ctx.save();
      ctx.globalAlpha = p.a;
      ctx.translate(p.x % W, p.y);
      ctx.rotate(p.rot * Math.PI / 180);
      ctx.font = p.sz + "px Arial";
      ctx.textAlign = "center";
      ctx.fillText(p.em, 0, 0);
      ctx.restore();
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

// ── SCROLL REVEAL ──
(function(){
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if(e.isIntersecting) e.target.classList.add("vis");
    });
  }, { threshold: 0.1 });
  document.querySelectorAll(".r0,.rl,.rr").forEach(el => {
    obs.observe(el);
  });
})();

// ── SCRATCH CARD ──
(function(){
  const wrap = document.getElementById("scWrap");
  const rev  = document.getElementById("scReveal");
  const cv   = document.getElementById("scratchCanvas");
  const ctx  = cv.getContext("2d");
  const done = document.getElementById("scDone");
  let drawing = false, finished = false;

  function init(){
    const rect = rev.getBoundingClientRect();
    const W = rect.width, H = rect.height;
    cv.width = W; cv.height = H;
    cv.style.width = W + "px"; cv.style.height = H + "px";

    // Fill
    const g = ctx.createLinearGradient(0,0,W,H);
    g.addColorStop(0,"#06001A"); g.addColorStop(.5,"#0A0028"); g.addColorStop(1,"#06001A");
    ctx.fillStyle = g; ctx.fillRect(0,0,W,H);

    // Shimmer dots
    for(let i = 0; i < 300; i++){
      const c2 = Math.random() > 0.5 ? "rgba(200,160,0," : "rgba(120,20,160,";
      ctx.beginPath();
      ctx.arc(Math.random()*W, Math.random()*H, Math.random()*1.8+.3, 0, Math.PI*2);
      ctx.fillStyle = c2 + (Math.random()*.4+.1) + ")";
      ctx.fill();
    }

    // Border
    ctx.strokeStyle = "rgba(200,160,0,.7)"; ctx.lineWidth = 2;
    ctx.strokeRect(1,1,W-2,H-2);

    // Text
    ctx.textAlign = "center"; ctx.textBaseline = "middle";
    ctx.shadowColor = "rgba(0,0,0,.9)"; ctx.shadowBlur = 12;
    ctx.fillStyle = "rgba(200,160,0,.85)";
    ctx.font = "bold " + Math.round(W*.064) + "px Noto Serif Devanagari,serif";
    ctx.fillText("✦ यहाँ खरोंचें ✦", W/2, H*.3);
    ctx.fillStyle = "rgba(255,229,100,.7)";
    ctx.font = Math.round(W*.046) + "px Noto Serif Devanagari,serif";
    ctx.fillText("शुभ मुहूर्त जानें", W/2, H*.5);
    ctx.font = Math.round(W*.088) + "px Arial";
    ctx.fillText("💍", W/2, H*.72);
    ctx.shadowBlur = 0; ctx.textAlign = "left"; ctx.textBaseline = "alphabetic";
  }
  setTimeout(init, 250);
  window.addEventListener("resize", () => setTimeout(init, 150));

  function getPos(e){
    const r = cv.getBoundingClientRect();
    const sx = cv.width/r.width, sy = cv.height/r.height;
    if(e.touches) return { x:(e.touches[0].clientX-r.left)*sx, y:(e.touches[0].clientY-r.top)*sy };
    return { x:(e.clientX-r.left)*sx, y:(e.clientY-r.top)*sy };
  }
  function doScratch(e){
    e.preventDefault();
    if(!drawing) return;
    const {x,y} = getPos(e);
    ctx.globalCompositeOperation = "destination-out";
    ctx.beginPath(); ctx.arc(x, y, 30, 0, Math.PI*2); ctx.fill();
    checkDone();
  }
  function checkDone(){
    if(finished) return;
    const d = ctx.getImageData(0,0,cv.width,cv.height).data;
    let cleared = 0;
    for(let i=3; i<d.length; i+=4) if(d[i]<128) cleared++;
    if(cleared / (d.length/4) > 0.44){
      finished = true;
      cv.style.transition = "opacity .9s ease";
      cv.style.opacity = "0";
      setTimeout(() => cv.style.display = "none", 900);
      done.classList.add("show");
      burst();
    }
  }
  cv.addEventListener("mousedown", e => { drawing=true; doScratch(e); });
  cv.addEventListener("mousemove", doScratch);
  window.addEventListener("mouseup", () => drawing=false);
  cv.addEventListener("touchstart", e => { drawing=true; doScratch(e); }, {passive:false});
  cv.addEventListener("touchmove", doScratch, {passive:false});
  window.addEventListener("touchend", () => drawing=false);

  function burst(){
    const colors = ["#C8A000","#FF6B00","#FF69B4","#FFE566","#00E5FF","#fff","#9C27B0"];
    for(let i=0; i<80; i++){
      const d = document.createElement("div");
      const bx = wrap.getBoundingClientRect();
      const x = bx.left + Math.random()*bx.width;
      const y = bx.top + bx.height/2;
      const sz = Math.random()*9+4;
      d.style.cssText = `position:fixed;left:${x}px;top:${y}px;width:${sz}px;height:${sz}px;background:${colors[Math.floor(Math.random()*colors.length)]};border-radius:${Math.random()>.5?"50%":"2px"};pointer-events:none;z-index:9999;transition:transform ${.7+Math.random()*.9}s ease-out,opacity 1s ease-out`;
      document.body.appendChild(d);
      setTimeout(() => {
        const a = (Math.random()-.5)*400;
        const dist = 100+Math.random()*150;
        d.style.transform = `translate(${Math.cos(a)*dist}px,${Math.sin(a)*dist-100}px) rotate(${a}deg)`;
        d.style.opacity = "0";
      }, 40);
      setTimeout(() => d.remove(), 1800);
    }
  }
})();
</script>
</body>
</html>
